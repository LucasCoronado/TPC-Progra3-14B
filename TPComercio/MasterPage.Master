                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNavDropdown">

                    <ul class="navbar-nav d-flex flex-column flex-lg-row w-100">

                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="#">Panel Principal</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="NuevaVenta.aspx">Nueva Venta</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Administración</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="Productos.aspx">Gestión de Productos</a></li>
                                <li><a class="dropdown-item" href="Clientes.aspx">Gestión de Clientes</a></li>
